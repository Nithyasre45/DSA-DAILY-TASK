import java.util.Scanner;

class Node {
    int data;
    Node next;

    Node(int val) {
        data = val;
        next = null;
    }
}

public class Main {

    // Insert at end
    static Node insert(Node head, int val) {
        Node newNode = new Node(val);

        if (head == null)
            return newNode;

        Node temp = head;
        while (temp.next != null)
            temp = temp.next;

        temp.next = newNode;
        return head;
    }

    // Add two numbers
    static Node addTwoNumbers(Node l1, Node l2) {

        Node dummy = new Node(0);
        Node temp = dummy;

        int carry = 0;

        while (l1 != null || l2 != null || carry != 0) {

            int sum = carry;

            if (l1 != null) {
                sum += l1.data;
                l1 = l1.next;
            }

            if (l2 != null) {
                sum += l2.data;
                l2 = l2.next;
            }

            carry = sum / 10;

            temp.next = new Node(sum % 10);
            temp = temp.next;
        }

        return dummy.next;
    }

    // Display list
    static void display(Node head) {
        while (head != null) {
            System.out.print(head.data + " ");
            head = head.next;
        }
    }

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        Node l1 = null;
        Node l2 = null;
        while (true) {
            int val = sc.nextInt();
            if (val == -1)
                break;
            l1 = insert(l1, val);
        }
        while (true) {
            int val = sc.nextInt();
            if (val == -1)
                break;
            l2 = insert(l2, val);
        }

        Node result = addTwoNumbers(l1, l2);

        System.out.print("Result: ");
        display(result);
    }
}
