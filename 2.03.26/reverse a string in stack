import java.util.*;
class Node{
    char data;
    Node next;
    
Node(char data){
    this.data=data;
    this.next=null;
}
}
    public class Main{
        Node top=null;
    
    void push(char data){
        Node newNode=new Node(data);
        newNode.next=top;
        top=newNode;
        
    }
    
    char pop(){
        if(top == null){
            return'\0';
        }
        
        char value=top.data;
        top=top.next;
        return value;
    }
    
    boolean isEmpty(){
        return top==null;
    }

    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        Main stack=new Main();
        String str=sc.nextLine();
        
        for(int i=0;i<str.length();i++){
            stack.push(str.charAt(i));
        }
        String rev="";
        while(!stack.isEmpty()){
        rev+=stack.pop();
        }
        System.out.print(rev);
        }
    }
